# Скопируйте в .env и заполните значения:
#   cp .env.example .env

# --- Gmail SMTP (отправка кодов) ---
GMAIL_USER=your@gmail.com
# Пароль приложения Google (не обычный пароль!)
# myaccount.google.com → Безопасность → Пароли приложений
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# --- CORS для backend (через запятую) ---
# При деплое через nginx оставьте http://localhost или укажите ваш домен
CORS_ORIGINS=http://localhost,http://127.0.0.1

# --- Frontend ---
# Production (docker-compose.yml + nginx): оставьте пустым — запросы идут на тот же домен (/api/...)
NEXT_PUBLIC_API_URL=
# Dev (docker-compose.dev.yml): http://localhost:8000

# --- Порт nginx на хосте ---
HTTP_PORT=80
