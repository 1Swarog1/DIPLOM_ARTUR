# Gmail — с твоей почты на указанный адрес
GMAIL_USER=your@gmail.com
# Пароль приложения (не обычный!): myaccount.google.com → Безопасность → Пароли приложений
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# CORS (через запятую). Для docker-compose + nginx: http://localhost или ваш домен
CORS_ORIGINS=http://localhost,http://127.0.0.1
